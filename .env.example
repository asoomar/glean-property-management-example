# Glean instance (sandbox)
GLEAN_SERVER_URL=https://support-lab-be.glean.com

# API tokens (use separate tokens per API namespace)
GLEAN_INDEXING_API_TOKEN=your-indexing-api-token
GLEAN_SEARCH_API_TOKEN=your-search-api-token
GLEAN_CLIENT_API_TOKEN=your-client-api-token

GLEAN_DATASOURCE=interviewds6
GLEAN_OBJECT_TYPE=Article
GLEAN_VIEW_URL_BASE=https://northstarpm.example.com/docs

GLEAN_ACT_AS=alex@glean-sandbox.com

# Search / chat defaults
GLEAN_DEFAULT_TOP_K=5
GLEAN_CHAT_TIMEOUT_MS=120000
GLEAN_HTTP_TIMEOUT_MS=120000
